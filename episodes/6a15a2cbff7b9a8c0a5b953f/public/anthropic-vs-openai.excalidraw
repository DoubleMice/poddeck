    {"id":"oa-t","type":"text","x":70,"y":115,"width":230,"height":150,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":2,"version":1,"versionNonce":2,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":1,"text":"OpenAI\n自下而上 · 探索期最优\n\n• 明星研究员各自探索\n• Sam = 天使投资人\n• 项目上线 → 没人维护\n• 适合发散型探索\n\nGPTs → 浏览器 → Operator\n→ Sora → 很多项目浮现又消失","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"OpenAI\n自下而上 · 探索期最优\n\n• 明星研究员各自探索\n• Sam = 天使投资人\n• 项目上线 → 没人维护\n• 适合发散型探索\n\nGPTs → 浏览器 → Operator\n→ Sora → 很多项目浮现又消失","lineHeight":1.3,"baseline":166},

