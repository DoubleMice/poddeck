    {"id":"elec-t","type":"text","x":400,"y":115,"width":220,"height":170,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4,"version":1,"versionNonce":4,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":1,"text":"电动机工厂\n• 不需要主轴\n• 更大、更扁平\n• 电线灵活布局\n• 诞生了流水线\n\n= AI-native 团队\n  全栈 + Agent 协作\n  职能边界模糊","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"电动机工厂\n• 不需要主轴\n• 更大、更扁平\n• 电线灵活布局\n• 诞生了流水线\n\n= AI-native 团队\n  全栈 + Agent 协作\n  职能边界模糊","lineHeight":1.4,"baseline":188},

