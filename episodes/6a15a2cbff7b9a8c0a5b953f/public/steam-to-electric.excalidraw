    {"id":"steam-era","type":"rectangle","x":60,"y":100,"width":260,"height":200,"angle":0,"strokeColor":"#c92a2a","backgroundColor":"#ffa8a8","fillStyle":"hachure","strokeWidth":2,"strokeStyle":"solid","roughness":1.5,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":1,"version":1,"versionNonce":1,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false},
    {"id":"steam-t","type":"text","x":80,"y":115,"width":220,"height":170,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":2,"version":1,"versionNonce":2,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":1,"text":"蒸汽机工厂\n• 围绕一根主轴建造\n• 狭长形厂房\n• 皮带传动动力\n• 无法做流水线\n\n= 传统瀑布式开发\n  前端/后端/测试 分工明确","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"蒸汽机工厂\n• 围绕一根主轴建造\n• 狭长形厂房\n• 皮带传动动力\n• 无法做流水线\n\n= 传统瀑布式开发\n  前端/后端/测试 分工明确","lineHeight":1.4,"baseline":188},

