    {"id":"bottom-note","type":"text","x":60,"y":340,"width":580,"height":90,"angle":0,"strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":6,"version":1,"versionNonce":6,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":1,"text":"技术不会自动带来生产力提升。\n从蒸汽机到电动机，需要厂房物理结构变化 + 流水线生产组织变化。\nAI 时代同理：不是每个人装个 Cursor 就完事了，需要组织变革。","textAlign":"center","verticalAlign":"middle","containerId":null,"originalText":"技术不会自动带来生产力提升。\n从蒸汽机到电动机，需要厂房物理结构变化 + 流水线生产组织变化。\nAI 时代同理：不是每个人装个 Cursor 就完事了，需要组织变革。","lineHeight":1.5,"baseline":74},

    {"id":"key-insight","type":"text","x":100,"y":460,"width":500,"height":50,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":7,"version":1,"versionNonce":7,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"fontSize":15,"fontFamily":1,"text":"组织变化是人的变化——人的变化不是一分钟就变了，\n它可能要十年才会变。","textAlign":"center","verticalAlign":"middle","containerId":null,"originalText":"组织变化是人的变化——人的变化不是一分钟就变了，\n它可能要十年才会变。","lineHeight":1.4,"baseline":38}
