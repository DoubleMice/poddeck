      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 12,
      "fontFamily": 1,
      "text": "\"Diversification is really the\nthing that we're getting for free.\"\n\n\"The machine doesn't care whether\nit's calculating on 100 markets\nor 200 things.\"",
