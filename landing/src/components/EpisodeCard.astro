---
import type { EpisodeWithSource } from '../lib/data'
import { url } from '../lib/url'

interface Props {
  episode: EpisodeWithSource
}

const { episode } = Astro.props
const isGenerated = episode.status === 'generated'
const hasArticle = !!episode.article_path
const thumbnail = episode.thumbnail
const pendingLabel = episode.status === 'failed'
  ? 'generation failed'
  : episode.status === 'needs_transcript'
    ? 'waiting for transcript'
    : 'transcript ready · slides coming'
---

<article
  class="episode-card bg-white rounded-lg border border-stone-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col"
  data-has-slides={String(isGenerated)}
  data-has-article={String(hasArticle)}
>
  <div class="relative aspect-video bg-stone-100">
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={episode.title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-stone-100 to-stone-200 text-stone-400 text-xs">
        RSS Episode
      </div>
    )}
    {!isGenerated && (
      <div class="absolute inset-0 bg-stone-900/60 flex items-center justify-center">
          <span class="text-white text-xs bg-stone-800 px-3 py-1 rounded-full">
          {pendingLabel}
          </span>
      </div>
    )}
    <a
      href={url(`/sources/${episode.sourceRef.id}/`)}
      class="absolute top-2 left-2 text-xs text-white px-2 py-0.5 rounded-full font-medium hover:opacity-90 transition-opacity"
      style={`background-color: ${episode.sourceRef.color || '#525252'}`}
      onclick="event.stopPropagation()"
    >
      {episode.sourceRef.name}
    </a>
    {episode.duration && (
      <div class="absolute bottom-2 right-2 text-[10px] text-white bg-black/60 px-1.5 py-0.5 rounded">
        {episode.duration}
      </div>
    )}
  </div>

  <div class="p-4 flex-1 flex flex-col">
    <h3 class="font-semibold text-base leading-snug mb-2 line-clamp-2">
      {episode.title}
    </h3>

    {episode.guest && (
      <div class="text-xs text-stone-500 mb-2">
        {episode.guest}{episode.guest_role ? ` · ${episode.guest_role}` : ''}
      </div>
    )}

    {episode.summary && (
      <p class="text-sm text-stone-600 line-clamp-3 mb-3 leading-relaxed">
        {episode.summary.replace(/\n/g, ' ')}
      </p>
    )}

    {episode.tags && episode.tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-3">
        {episode.tags.slice(0, 4).map(tag => (
          <a
            href={url(`/tags/${tag}/`)}
            class="text-[10px] px-2 py-0.5 bg-stone-100 hover:bg-blue-100 text-stone-600 hover:text-blue-700 rounded-full transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <div class="mt-auto pt-2 flex items-center justify-between">
      <div class="flex gap-3">
        {isGenerated ? (
          <a
            href={url(episode.base || `/episodes/${episode.id}/`)}
            class="text-sm font-medium text-blue-600 hover:text-blue-800"
          >
            查看 slides →
          </a>
        ) : (
          <span class="text-xs text-stone-400">{episode.status === 'failed' ? '生成失败' : episode.status === 'needs_transcript' ? '等待转写' : 'slides 未生成'}</span>
        )}
        {hasArticle && (
          <a
            href={url(episode.article_path!)}
            class="text-sm font-medium text-green-600 hover:text-green-800"
          >
            阅读文章 →
          </a>
        )}
      </div>
      <a
        href={episode.url}
        target="_blank"
        rel="noopener"
        class="text-xs text-stone-400 hover:text-stone-600"
      >
        原文 ↗
      </a>
    </div>
  </div>
</article>
