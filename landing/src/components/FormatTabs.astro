<div class="format-tabs flex gap-2 mb-6" id="format-tabs">
  <button class="tab-btn active px-4 py-1.5 rounded-full text-sm font-medium border border-stone-200 bg-blue-600 text-white" data-format="slides">
    幻灯片
  </button>
  <button class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium border border-stone-200 text-stone-600 hover:bg-stone-100" data-format="articles">
    文章
  </button>
</div>

<script is:inline>
  (function() {
    var tabs = document.querySelectorAll('#format-tabs .tab-btn')
    var grid = document.getElementById('episode-grid')
    if (!tabs.length || !grid) return

    tabs.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var format = btn.dataset.format
        tabs.forEach(function(b) {
          b.classList.remove('active', 'bg-blue-600', 'text-white')
          b.classList.add('text-stone-600')
        })
        btn.classList.add('active', 'bg-blue-600', 'text-white')
        btn.classList.remove('text-stone-600')

        var attr = format === 'slides' ? 'data-has-slides' : 'data-has-article'
        grid.querySelectorAll('.episode-card').forEach(function(card) {
          card.style.display = card.getAttribute(attr) === 'true' ? '' : 'none'
        })

        // hide empty sections
        grid.querySelectorAll('[data-format-section]').forEach(function(section) {
          var hasVisible = false
          section.querySelectorAll('.episode-card').forEach(function(c) {
            if (c.style.display !== 'none') hasVisible = true
          })
          section.style.display = hasVisible ? '' : 'none'
        })
      })
    })
  })()
</script>
