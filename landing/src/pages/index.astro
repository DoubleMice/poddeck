---
import Base from '../layouts/Base.astro'
import EpisodeCard from '../components/EpisodeCard.astro'
import FormatTabs from '../components/FormatTabs.astro'
import SearchBox from '../components/SearchBox.astro'
import { loadEpisodes, loadSourcesWithFallbacks, collectTags, CATEGORIES } from '../lib/data'
import { url } from '../lib/url'

const episodes = loadEpisodes()
const sources = loadSourcesWithFallbacks(episodes)
const tags = collectTags(episodes)

const generated = episodes.filter(e => e.status === 'generated')
const pending = episodes.filter(e => e.status !== 'generated' && e.status !== 'failed')
const failed = episodes.filter(e => e.status === 'failed')
const latest = [...episodes]
  .filter(e => e.status === 'generated')
  .sort((a, b) => (b.generated_sort ?? 0) - (a.generated_sort ?? 0)
    || (b.published ?? '').localeCompare(a.published ?? ''))
  .slice(0, 12)

// Group generated episodes by category (in priority order)
const generatedByCategory = CATEGORIES.map(cat => ({
  ...cat,
  episodes: generated.filter(e => e.category === cat.id),
})).filter(g => g.episodes.length > 0)

// Uncategorized generated (old episodes without category)
const uncategorizedGenerated = generated.filter(e => !e.category)
---

<Base title="PodDeck">
  <!-- Hero -->
  <section class="mb-10 max-w-3xl">
    <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight mb-4 leading-tight">
      把你看的播客<br />变成可翻的 slides
    </h1>
    <p class="text-stone-600 text-lg leading-relaxed">
      PodDeck 从播客 RSS 获取访谈与 transcript，分析内容，自动生成结构化的 Slidev 演示文稿。
      每次你点开一个节目，看到的是 15 分钟读完、有手绘图和核心论点的幻灯片。
    </p>
  </section>

  <!-- Search -->
  <SearchBox episodes={episodes} />

  <!-- Stats strip -->
  <section class="grid grid-cols-3 gap-4 mb-10 max-w-2xl">
    <div class="p-3 bg-white rounded border border-stone-200">
      <div class="text-2xl font-bold text-stone-900">{sources.length}</div>
      <div class="text-xs text-stone-500 mt-1">订阅源头</div>
    </div>
    <div class="p-3 bg-white rounded border border-stone-200">
      <div class="text-2xl font-bold text-stone-900">{episodes.length}</div>
      <div class="text-xs text-stone-500 mt-1">收录节目</div>
    </div>
    <div class="p-3 bg-white rounded border border-stone-200">
      <div class="text-2xl font-bold text-stone-900">{generated.length}</div>
      <div class="text-xs text-stone-500 mt-1">已生成 slides</div>
    </div>
  </section>

  <!-- Top tags + sources first -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
    {tags.length > 0 && (
      <div class="p-5 bg-white rounded-lg border border-stone-200">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-4">
          热门标签
        </h2>
        <div class="flex flex-wrap gap-2">
          {tags.slice(0, 24).map(({ tag, count }) => (
            <a
              href={url(`/tags/${tag}/`)}
              class="text-sm px-3 py-1 bg-stone-50 border border-stone-200 hover:border-blue-400 hover:bg-blue-50 rounded-full text-stone-700 hover:text-blue-700 transition-colors"
            >
              #{tag}
              <span class="ml-1 text-stone-400 text-xs">{count}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="p-5 bg-white rounded-lg border border-stone-200">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-4">
        订阅源头
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {sources.map(source => {
          const count = episodes.filter(e => e.source === source.id).length
          return (
            <a
              href={url(`/sources/${source.id}/`)}
              class="p-3 bg-stone-50 border border-stone-200 hover:border-stone-400 hover:bg-white rounded-lg flex items-start gap-3 transition-all"
            >
              <div
                class="w-3 h-3 rounded-full mt-1.5 flex-shrink-0"
                style={`background-color: ${source.color || '#525252'}`}
              />
              <div class="flex-1 min-w-0">
                <div class="font-semibold text-sm truncate">{source.name}</div>
                <div class="text-xs text-stone-400 mt-1">{count} 集</div>
              </div>
            </a>
          )
        })}
      </div>
    </div>
  </section>

  <!-- Latest additions -->
  {latest.length > 0 && (
    <section class="mb-12">
      <div class="flex items-end justify-between gap-4 mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500">
          最新添加
        </h2>
        <div class="text-xs text-stone-400">按 slides 生成时间排序</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latest.map(ep => <EpisodeCard episode={ep} />)}
      </div>
    </section>
  )}

  <!-- Format tabs + generated episodes by category -->
  <div id="episode-grid">
    <FormatTabs />

    {generatedByCategory.map(group => (
      <section class="mb-12" data-format-section>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-4">
          {group.label}
          <span class="ml-2 text-stone-400 font-normal normal-case">{group.episodes.length} 集</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {group.episodes.map(ep => <EpisodeCard episode={ep} />)}
        </div>
      </section>
    ))}

    {uncategorizedGenerated.length > 0 && (
      <section class="mb-12" data-format-section>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-4">
          其他
          <span class="ml-2 text-stone-400 font-normal normal-case">{uncategorizedGenerated.length} 集</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {uncategorizedGenerated.map(ep => <EpisodeCard episode={ep} />)}
        </div>
      </section>
    )}
  </div>

  <!-- Pending episodes -->
  {pending.length > 0 && (
    <section class="mb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-4">
        待处理 · RSS transcript / 等待转写
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {pending.map(ep => <EpisodeCard episode={ep} />)}
      </div>
    </section>
  )}

  {failed.length > 0 && (
    <section class="mb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-red-500 mb-4">
        需要排障
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {failed.map(ep => <EpisodeCard episode={ep} />)}
      </div>
    </section>
  )}

</Base>
